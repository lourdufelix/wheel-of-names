{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src"
  },
  "package": {
    "productName": "wheel-of-names",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.wheelofnames.app",
      "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": false,
        "title": "Wheel of Names",
        "width": 900,
        "height": 640,
        "center": true
      }
    ]
  }
}
